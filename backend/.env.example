# MongoDB bağlantı adresi (MongoDB Atlas veya lokal)
# Atlas için: mongodb+srv://username:password@cluster.mongodb.net/yanitliyor
# Lokal için: mongodb://localhost:27017/yanitliyor
MONGODB_URI=mongodb://localhost:27017/yanitliyor

# JWT gizli anahtar (güçlü bir string olmalı)
JWT_SECRET=yanitliyor_super_secret_jwt_key_2026

# JWT süresi
JWT_EXPIRES_IN=30d

# Sunucu portu
PORT=5001

# Frontend URL (CORS için)
FRONTEND_URL=http://localhost:5173
